<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Hero ─────────────────────────────────────── -->
            <FrameLayout
                android:id="@+id/hero_section"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/bg_hero_gradient">

                <!-- Decorative layer stack (right side) -->
                <FrameLayout
                    android:layout_width="130dp"
                    android:layout_height="210dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:rotation="-8"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Layer 1: background -->
                    <View
                        android:layout_width="88dp"
                        android:layout_height="148dp"
                        android:layout_gravity="center"
                        android:translationX="-10dp"
                        android:translationY="10dp"
                        android:background="#18FFFFFF"
                        android:backgroundTint="#18FFFFFF" />

                    <!-- Layer 2: clock -->
                    <View
                        android:layout_width="88dp"
                        android:layout_height="148dp"
                        android:layout_gravity="center"
                        android:background="#30FFFFFF" />

                    <!-- Clock text hint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="20dp"
                        android:text="12:34"
                        android:textColor="#60FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-light" />

                    <!-- Layer 3: subject silhouette -->
                    <View
                        android:layout_width="42dp"
                        android:layout_height="72dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:translationX="10dp"
                        android:translationY="-8dp"
                        android:background="#70FFFFFF" />
                </FrameLayout>

                <!-- Hero text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="148dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Build your"
                        android:textColor="#AAFFFFFF"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="wallpaper."
                        android:textColor="#FFFFFF"
                        android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                        android:letterSpacing="-0.03" />
                </LinearLayout>

            </FrameLayout>

            <!-- ── Steps section ───────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- CARD 1: Background -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_background"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:strokeWidth="0dp"
                    app:rippleColor="?attr/colorControlHighlight">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_step_badge"
                                android:backgroundTint="?attr/colorPrimaryContainer">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="1"
                                    android:textColor="?attr/colorOnPrimaryContainer"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Background Image"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="?attr/colorOnSurface" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="The scene behind everything"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <com.google.android.material.chip.Chip
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Required"
                                android:checkable="false"
                                app:chipBackgroundColor="?attr/colorErrorContainer"
                                app:chipMinHeight="28dp"
                                android:textColor="?attr/colorError"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="172dp"
                            android:background="@drawable/bg_image_placeholder">

                            <LinearLayout
                                android:id="@+id/bg_placeholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_add_photo"
                                    android:alpha="0.3"
                                    android:contentDescription="Add photo" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Tap to choose a photo"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/iv_bg_thumb"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:visibility="gone"
                                android:contentDescription="Background preview" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_bg_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="No image selected"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD 2: Font -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_font"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:strokeWidth="0dp"
                    app:rippleColor="?attr/colorControlHighlight">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_step_badge"
                                android:backgroundTint="?attr/colorSecondaryContainer">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="2"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Clock Font"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="?attr/colorOnSurface" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Custom .ttf typeface for the clock"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <com.google.android.material.chip.Chip
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Optional"
                                android:checkable="false"
                                app:chipBackgroundColor="?attr/colorSecondaryContainer"
                                app:chipMinHeight="28dp"
                                android:textColor="?attr/colorOnSecondaryContainer"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="@drawable/bg_font_preview">
                            <ImageView
                                android:id="@+id/iv_font_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_font"
                                android:alpha="0.2"
                                android:contentDescription="Font icon" />
                            <TextView
                                android:id="@+id/tv_font_preview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="12:34"
                                android:textSize="46sp"
                                android:textColor="?attr/colorPrimary"
                                android:visibility="invisible" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_font_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Using system default font"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD 3: Subject -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:strokeWidth="0dp"
                    app:rippleColor="?attr/colorControlHighlight">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_step_badge"
                                android:backgroundTint="?attr/colorTertiaryContainer">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="3"
                                    android:textColor="?attr/colorOnTertiaryContainer"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cutout Subject"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="?attr/colorOnSurface" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PNG placed in front of the clock"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <com.google.android.material.chip.Chip
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Required"
                                android:checkable="false"
                                app:chipBackgroundColor="?attr/colorErrorContainer"
                                app:chipMinHeight="28dp"
                                android:textColor="?attr/colorError"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="172dp"
                            android:background="@drawable/bg_image_placeholder">

                            <LinearLayout
                                android:id="@+id/subject_placeholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_person_add"
                                    android:alpha="0.3"
                                    android:contentDescription="Add subject" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Tap to choose a cutout PNG"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/iv_subject_thumb"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:padding="14dp"
                                android:visibility="gone"
                                android:contentDescription="Subject preview" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_subject_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="No subject selected"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Continue button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_continue"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:enabled="false"
                    android:text="Continue to Editor"
                    android:textSize="16sp"
                    android:letterSpacing="0.02"
                    app:cornerRadius="20dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

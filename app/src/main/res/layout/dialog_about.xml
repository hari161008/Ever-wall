<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Shape-based banner: colorPrimaryContainer + decorative circles -->
    <FrameLayout
        android:id="@+id/aboutBannerFrame"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="?attr/colorPrimaryContainer"
        android:clipChildren="true"
        android:clipToPadding="true">

        <!-- Large solid circle — top right, partially clipped -->
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-55dp"
            android:layout_marginEnd="-45dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.13" />

        <!-- Medium solid circle — bottom left, partially clipped -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-32dp"
            android:layout_marginStart="-22dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.09" />

        <!-- Small solid circle — top left area -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="14dp"
            android:layout_marginStart="18dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.11" />

        <!-- Ring circle — bottom right -->
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-28dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/bg_about_deco_ring"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.18" />

        <!-- Small ring — center left -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="90dp"
            android:background="@drawable/bg_about_deco_ring"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.12" />

        <!-- Tiny solid dot — mid right area -->
        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="60dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.14" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="26sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ever Wall"
                android:textSize="22sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0"
                android:textSize="12sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:alpha="0.65"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp">

        <!-- THEME label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textSize="11sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Theme"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_theme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_auto"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Auto"
                        android:textSize="11sp"
                        app:cornerRadius="17dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_light"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Light"
                        android:textSize="11sp"
                        app:cornerRadius="17dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_dark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Dark"
                        android:textSize="11sp"
                        app:cornerRadius="17dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- APPEARANCE label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textSize="11sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <!-- Background behind preview toggle card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background behind preview"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coloured banner design in the editor"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_bg_behind_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:checked="false" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- COMMUNITY label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY"
            android:textSize="11sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <!-- Support Group card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_support_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_primary"
                    android:backgroundTint="?attr/colorPrimaryContainer"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_people"
                        android:tint="?attr/colorOnPrimaryContainer"
                        android:contentDescription="Community" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Support Group"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updates · Bug Reports · Feature Requests"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- App Channel card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_app_channel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_secondary"
                    android:backgroundTint="?attr/colorSecondaryContainer"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_campaign"
                        android:tint="?attr/colorOnSecondaryContainer"
                        android:contentDescription="Channel" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Channel"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Discover cool apps · Announcements"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginBottom="16dp" />

        <!-- ABOUT label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textSize="11sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Made with ♥ by SVHP"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

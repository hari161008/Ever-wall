<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Hero banner ─────────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/aboutBannerFrame"
        android:layout_width="match_parent"
        android:layout_height="148dp"
        android:background="?attr/colorPrimaryContainer"
        android:clipChildren="true"
        android:clipToPadding="true">

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-60dp"
            android:layout_marginEnd="-50dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.10" />

        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-36dp"
            android:layout_marginStart="-24dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.07" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="18dp"
            android:layout_marginStart="22dp"
            android:background="@drawable/bg_about_deco_ring"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.14" />

        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-30dp"
            android:layout_marginEnd="36dp"
            android:background="@drawable/bg_about_deco_ring"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.16" />

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="70dp"
            android:background="@drawable/bg_about_deco_circle"
            android:backgroundTint="?attr/colorOnPrimaryContainer"
            android:alpha="0.13" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="28sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ever Wall"
                android:textSize="24sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 2.0.0"
                android:textSize="12sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:alpha="0.70"
                android:layout_marginTop="3dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- ════════════════  UPDATES  ════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPDATES"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:paddingTop="12dp"
                android:paddingBottom="6dp" />

            <!-- Check for Updates -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_check_updates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_about_deco_circle"
                        android:backgroundTint="?attr/colorSecondary"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_update"
                            android:tint="?attr/colorOnSecondary"
                            android:contentDescription="Updates" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check for Updates"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSecondaryContainer" />
                        <TextView
                            android:id="@+id/tv_update_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to check for a new version"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:alpha="0.72"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_update"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="10dp"
                        android:visibility="gone"
                        android:indeterminate="true"
                        android:indeterminateTint="?attr/colorOnSecondaryContainer" />

                    <ImageView
                        android:id="@+id/iv_update_arrow"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="10dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="?attr/colorOnSecondaryContainer"
                        android:alpha="0.70"
                        android:contentDescription="Go" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Auto Check for Updates -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto Check for Updates"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show update prompt on app launch"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_auto_check_updates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:checked="true" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════  THEME  ════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THEME"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:paddingTop="4dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="App Theme"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_theme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_theme_auto"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Auto"
                            android:textSize="11sp"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_theme_light"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Light"
                            android:textSize="11sp"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_theme_dark"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Dark"
                            android:textSize="11sp"
                            app:cornerRadius="16dp" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════  APPEARANCE  ════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:paddingTop="4dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Background behind preview"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coloured banner in the editor"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_bg_behind_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:checked="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════  COMMUNITY  ════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMUNITY"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:paddingTop="4dp"
                android:paddingBottom="6dp" />

            <!-- Support Group -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_support_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_about_deco_circle"
                        android:backgroundTint="?attr/colorPrimaryContainer"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_people"
                            android:tint="?attr/colorOnPrimaryContainer"
                            android:contentDescription="Community" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Support Group"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Updates · Bug Reports · Feature Requests"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="?attr/colorOnSurfaceVariant"
                        android:alpha="0.60"
                        android:contentDescription="Open" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App Channel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_channel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_about_deco_circle"
                        android:backgroundTint="?attr/colorTertiaryContainer"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_campaign"
                            android:tint="?attr/colorOnTertiaryContainer"
                            android:contentDescription="Channel" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="App Channel"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discover cool apps · Announcements"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="?attr/colorOnSurfaceVariant"
                        android:alpha="0.60"
                        android:contentDescription="Open" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════  ABOUT  ════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:paddingTop="4dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Made with ♥ by SVHP"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <!-- Banner-style background — shown when "Background behind preview" is ON -->
        <FrameLayout
            android:id="@+id/preview_bg_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipChildren="true"
            android:clipToPadding="true">

            <!-- ── Geometric shapes (edges only, avoid center) ──────── -->
            <View android:layout_width="200dp" android:layout_height="200dp"
                android:layout_gravity="top|end" android:layout_marginTop="-70dp" android:layout_marginEnd="-55dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.08"/>

            <View android:layout_width="130dp" android:layout_height="130dp"
                android:layout_gravity="bottom|start" android:layout_marginBottom="-45dp" android:layout_marginStart="-35dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.07"/>

            <View android:layout_width="90dp" android:layout_height="90dp"
                android:layout_gravity="center_vertical|start" android:layout_marginStart="10dp"
                android:background="@drawable/bg_about_deco_ring"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.10"/>

            <View android:layout_width="120dp" android:layout_height="120dp"
                android:layout_gravity="bottom|end" android:layout_marginBottom="70dp" android:layout_marginEnd="-32dp"
                android:background="@drawable/bg_about_deco_ring"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.09"/>

            <!-- Diamond — top left -->
            <View android:layout_width="38dp" android:layout_height="38dp"
                android:layout_gravity="top|start" android:layout_marginTop="70dp" android:layout_marginStart="20dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer"
                android:rotation="45" android:alpha="0.10"/>

            <!-- Diamond — right edge -->
            <View android:layout_width="52dp" android:layout_height="52dp"
                android:layout_gravity="center_vertical|end" android:layout_marginEnd="14dp" android:layout_marginTop="-100dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer"
                android:rotation="45" android:alpha="0.08"/>

            <!-- Diamond — bottom center -->
            <View android:layout_width="30dp" android:layout_height="30dp"
                android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="120dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer"
                android:rotation="45" android:alpha="0.09"/>

            <!-- Pill horizontal — top start -->
            <View android:layout_width="70dp" android:layout_height="14dp"
                android:layout_gravity="top|start" android:layout_marginTop="28dp" android:layout_marginStart="45dp"
                android:background="@drawable/bg_deco_pill"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.08"/>

            <!-- Pill tilted — bottom right -->
            <View android:layout_width="60dp" android:layout_height="12dp"
                android:layout_gravity="bottom|end" android:layout_marginBottom="155dp" android:layout_marginEnd="46dp"
                android:background="@drawable/bg_deco_pill"
                android:backgroundTint="?attr/colorOnPrimaryContainer"
                android:rotation="-18" android:alpha="0.09"/>

            <!-- Pill vertical — left -->
            <View android:layout_width="12dp" android:layout_height="55dp"
                android:layout_gravity="center_vertical|start" android:layout_marginStart="44dp" android:layout_marginTop="-70dp"
                android:background="@drawable/bg_deco_pill"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.08"/>

            <!-- Small ring — top right inner -->
            <View android:layout_width="56dp" android:layout_height="56dp"
                android:layout_gravity="top|end" android:layout_marginTop="88dp" android:layout_marginEnd="24dp"
                android:background="@drawable/bg_about_deco_ring"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.08"/>

            <!-- Tiny ring — center-left upper -->
            <View android:layout_width="40dp" android:layout_height="40dp"
                android:layout_gravity="top|start" android:layout_marginTop="150dp" android:layout_marginStart="18dp"
                android:background="@drawable/bg_about_deco_ring"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.07"/>

            <!-- Tiny dot -->
            <View android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="bottom|end" android:layout_marginBottom="190dp" android:layout_marginEnd="70dp"
                android:background="@drawable/bg_about_deco_circle"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.11"/>

            <!-- Large ring — top left clipped -->
            <View android:layout_width="150dp" android:layout_height="150dp"
                android:layout_gravity="top|start" android:layout_marginTop="-55dp" android:layout_marginStart="-48dp"
                android:background="@drawable/bg_about_deco_ring"
                android:backgroundTint="?attr/colorOnPrimaryContainer" android:alpha="0.08"/>

            <!-- Pill diagonal — top right -->
            <View android:layout_width="50dp" android:layout_height="10dp"
                android:layout_gravity="top|end" android:layout_marginTop="48dp" android:layout_marginEnd="75dp"
                android:background="@drawable/bg_deco_pill"
                android:backgroundTint="?attr/colorOnPrimaryContainer"
                android:rotation="28" android:alpha="0.08"/>

            <!-- ── Clouds ────────────────────────────────────────────── -->
            <ImageView
                android:layout_width="120dp" android:layout_height="60dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="22dp" android:layout_marginStart="8dp"
                android:src="@drawable/ic_cloud"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.22"
                android:contentDescription="@null"/>

            <ImageView
                android:layout_width="90dp" android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="44dp" android:layout_marginEnd="8dp"
                android:src="@drawable/ic_cloud"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.16"
                android:contentDescription="@null"/>

            <ImageView
                android:layout_width="70dp" android:layout_height="38dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:src="@drawable/ic_cloud"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.14"
                android:contentDescription="@null"/>

            <!-- ── Sun (light mode) ──────────────────────────────────── -->
            <ImageView
                android:id="@+id/iv_sun"
                android:layout_width="64dp" android:layout_height="64dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp" android:layout_marginEnd="8dp"
                android:src="@drawable/ic_sun"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.45"
                android:visibility="gone"
                android:contentDescription="@null"/>

            <!-- ── Moon (dark mode) ──────────────────────────────────── -->
            <ImageView
                android:id="@+id/iv_moon"
                android:layout_width="56dp" android:layout_height="56dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp" android:layout_marginEnd="12dp"
                android:src="@drawable/ic_moon"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.42"
                android:visibility="gone"
                android:contentDescription="@null"/>

            <!-- ── Buildings (bottom) ────────────────────────────────── -->
            <ImageView
                android:layout_width="match_parent" android:layout_height="130dp"
                android:layout_gravity="bottom"
                android:src="@drawable/ic_buildings"
                android:tint="?attr/colorOnPrimaryContainer"
                android:alpha="0.22"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>

        </FrameLayout>

        <!-- preview_area is full-width; card is sized+centered by applyExactSurfaceAspectRatio -->
        <FrameLayout
            android:id="@+id/preview_area"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_card"
                android:layout_width="200dp"
                android:layout_height="360dp"
                android:layout_gravity="center"
                app:cardCornerRadius="28dp"
                app:cardElevation="32dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#000000">
                <com.everwall.WallpaperEditorView
                    android:id="@+id/editor_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Floating sidebar overlay — scrollable so Set Time is never clipped -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/sidebar_scroll"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="top|end"
            android:paddingTop="12dp"
            android:paddingBottom="24dp"
            android:paddingEnd="4dp"
            android:paddingStart="2dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <!-- Reset button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginBottom="4dp"
                    android:text="Reset"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:letterSpacing="0.01"
                    app:cornerRadius="15dp"
                    app:icon="@drawable/ic_reset"
                    app:iconSize="13dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:elevation="6dp" />

                <!-- Day & Night UI — scrolls with sidebar, never hidden -->
                <LinearLayout
                    android:id="@+id/day_night_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Day / Night pill selector — compact -->
                    <LinearLayout
                        android:id="@+id/day_night_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="3dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_day"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginBottom="2dp"
                            android:text="Day"
                            android:textSize="11sp"
                            android:paddingStart="8dp"
                            android:paddingEnd="12dp"
                            app:cornerRadius="15dp"
                            app:icon="@drawable/ic_day"
                            app:iconSize="12dp"
                            app:iconGravity="textStart"
                            app:iconPadding="3dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_night"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Night"
                            android:textSize="11sp"
                            android:paddingStart="8dp"
                            android:paddingEnd="12dp"
                            app:cornerRadius="15dp"
                            app:icon="@drawable/ic_night"
                            app:iconSize="12dp"
                            app:iconGravity="textStart"
                            app:iconPadding="3dp" />

                    </LinearLayout>

                    <!-- Set Day / Set Night — two-line cards (label on top, time below) -->
                    <LinearLayout
                        android:id="@+id/set_time_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SET TIME"
                            android:textSize="8sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:letterSpacing="0.1"
                            android:paddingStart="2dp"
                            android:paddingBottom="5dp"
                            android:textAllCaps="true" />

                        <!-- Day time card -->
                        <LinearLayout
                            android:id="@+id/btn_set_day_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_set_time_card"
                            android:padding="7dp"
                            android:layout_marginBottom="4dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:src="@drawable/ic_day"
                                    android:tint="?attr/colorOnSurface"
                                    android:layout_marginEnd="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Day"
                                    android:textSize="9sp"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="sans-serif-medium" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_day_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6:00 AM"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurface"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <!-- Night time card -->
                        <LinearLayout
                            android:id="@+id/btn_set_night_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_set_time_card"
                            android:padding="7dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:src="@drawable/ic_night"
                                    android:tint="?attr/colorOnSurface"
                                    android:layout_marginEnd="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Night"
                                    android:textSize="9sp"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="sans-serif-medium" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_night_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7:00 PM"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurface"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

</merge>
